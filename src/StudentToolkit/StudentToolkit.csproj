<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <AppDesignerFolder>Properties</AppDesignerFolder>
	<NoWarn>IDE0290</NoWarn>
	<WarningsAsErrors>CS8602</WarningsAsErrors>
	<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	<ApplicationIcon>Resources\Assets\icon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\Assets\icon.ico" />
    <None Remove="Resources\Assets\Notification\error.png" />
    <None Remove="Resources\Assets\Notification\info.png" />
    <None Remove="Resources\Assets\Notification\warning.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" Version="1.1.77" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\StudentToolkit.Application\StudentToolkit.Application.csproj" />
    <ProjectReference Include="..\StudentToolkit.CustomControls\StudentToolkit.CustomControls.csproj" />
    <ProjectReference Include="..\StudentToolkit.Infrastructure\StudentToolkit.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\Assets\icon.ico" />
    <Resource Include="Resources\Assets\Notification\error.png" />
    <Resource Include="Resources\Assets\Notification\info.png" />
    <Resource Include="Resources\Assets\Notification\warning.png" />
    <Resource Include="Resources\Assets\Notification\ask.png" />
  </ItemGroup>

</Project>
