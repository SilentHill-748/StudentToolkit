<UserControl x:Class="StudentToolkit.MVVM.Views.Group.Create.AddStudentsToGroupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ViewModel="clr-namespace:StudentToolkit.MVVM.ViewModels.Presentation.Group.Create"
             d:DataContext="{d:DesignInstance Type=ViewModel:AddStudentsToGroupViewModel}"
             mc:Ignorable="d">

    <Grid Margin="100 10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Text="{Binding ViewTitle}"
            HorizontalAlignment="Center"
            FontSize="24"
            Margin="0 0 0 30"/>

        <Grid
            Grid.Column="2"
            Grid.Row="1"
            HorizontalAlignment="Center">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Row="0"
                VerticalAlignment="Center"
                Margin="0 0 0 10"
                Text="Фамилия"/>

            <TextBlock
                Grid.Row="1"
                VerticalAlignment="Center"
                Margin="0 0 0 10"
                Text="Имя"/>

            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                Margin="0 0 0 10"
                Text="Отчество"/>

            <TextBox
                Grid.Column="2"
                Grid.Row="0"
                VerticalAlignment="Center"
                Margin="0 0 0 10"
                Style="{StaticResource TextBoxStyle}"
                Text="{Binding Student.LastName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBox
                Grid.Column="2"
                Grid.Row="1"
                VerticalAlignment="Center"
                Margin="0 0 0 10"
                Style="{StaticResource TextBoxStyle}"
                Text="{Binding Student.FirstName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBox
                Grid.Column="2"
                Grid.Row="2"
                VerticalAlignment="Center"
                Margin="0 0 0 10"
                Style="{StaticResource TextBoxStyle}"
                Text="{Binding Student.MiddleName, UpdateSourceTrigger=PropertyChanged}"/>

            <Button
                Grid.Row="3"
                Grid.ColumnSpan="3"
                HorizontalAlignment="Left"
                Content="Добавить студента"
                Command="{Binding AddStudentCommand}"
                Style="{StaticResource ButtonStyle}"/>
        </Grid>

        <TextBlock
            Grid.Row="2"
            Text="Студенты"
            Margin="0 30 0 10"
            HorizontalAlignment="Center"/>

        <DataGrid
            Grid.Row="3"
            ItemsSource="{Binding Students}"
            Style="{StaticResource DataGridStyle}">

            <DataGrid.Columns>
                <DataGridTextColumn
                    Header="Фамилия"
                    Binding="{Binding LastName}"/>

                <DataGridTextColumn
                    Header="Имя"
                    Binding="{Binding FirstName}"/>

                <DataGridTextColumn
                    Header="Отчество"
                    Binding="{Binding MiddleName}"/>

                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource DataGridRemoveOperationButtonStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel
            Grid.Row="4"
            Margin="0 50 0 0"
            VerticalAlignment="Top"
            HorizontalAlignment="Center">

            <Button
                Content="Вернуться"
                Margin="0 0 25 0"
                Command="{Binding GoBackCommand}"
                Style="{StaticResource ButtonStyle}"/>

            <Button
                Content="Создать"
                Margin="0 0 25 0"
                Command="{Binding AsyncCreateGroupCommand}"
                Style="{StaticResource ButtonStyle}"/>

            <Button
                Content="Отмена"
                Margin="0 0 25 0"
                Command="{Binding CancelCommand}"
                Style="{StaticResource ButtonStyle}"/>
        </WrapPanel>
    </Grid>
</UserControl>
