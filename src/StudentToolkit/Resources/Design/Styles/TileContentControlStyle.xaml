<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:CustomControls="clr-namespace:StudentToolkit.WpfCore.CustomControls">

    <Style x:Key="TileContentControlStyle" TargetType="{x:Type CustomControls:TileContentControl}">
        <Setter Property="Background" Value="{DynamicResource ContentTileBackgroundBrush}"/>
        <Setter Property="Padding" Value="30 15"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CustomControls:TileContentControl}">
                    <Border
                        CornerRadius="25"
                        Background="{TemplateBinding Background}">
                        
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>